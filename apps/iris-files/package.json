{
  "name": "iris-files",
  "version": "0.1.2",
  "license": "MIT",
  "private": true,
  "description": "Iris Files - content-addressed file storage on Nostr",
  "repository": "https://git.iris.to/#/npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/iris-apps",
  "homepage": "https://git.iris.to/#/npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/iris-apps/apps/iris-files",
  "bugs": {
    "url": "https://git.iris.to/#/npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/iris-apps?tab=issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "vite",
    "dev:docs": "vite --config vite.docs.config.ts",
    "dev:git": "vite --config vite.git.config.ts",
    "dev:video": "vite --config vite.video.config.ts",
    "dev:maps": "vite --config vite.maps.config.ts",
    "dev:boards": "vite --config vite.boards.config.ts",
    "build:deps": "pnpm --dir ../.. --filter @hashtree/core build && pnpm --dir ../.. --filter @hashtree/index build && pnpm --dir ../.. --filter @hashtree/tree-root build && pnpm --dir ../.. --filter @hashtree/nostr build && pnpm --dir ../.. --filter ndk build && pnpm --dir ../.. --filter ndk-cache build",
    "build": "pnpm run build:deps && vite build",
    "build:docs": "pnpm run build:deps && vite build --config vite.docs.config.ts",
    "build:git": "pnpm run build:deps && vite build --config vite.git.config.ts",
    "build:video": "pnpm run build:deps && vite build --config vite.video.config.ts",
    "build:video:iris": "pnpm run build:video",
    "smoke:docs:iris": "node ./scripts/smoke-docs-iris-portable.mjs",
    "smoke:files:iris": "node ./scripts/smoke-files-iris-portable.mjs",
    "smoke:git:iris": "node ./scripts/smoke-git-iris-portable.mjs",
    "smoke:maps:iris": "node ./scripts/smoke-maps-iris-portable.mjs",
    "smoke:video:iris": "node ./scripts/smoke-video-iris-portable.mjs",
    "smoke:boards:iris": "node ./scripts/smoke-boards-iris-portable.mjs",
    "measure:video:thumbnails": "node ./scripts/measure-feed-thumbnail-load.mjs",
    "audit:video:thumbnails": "node ./scripts/audit-feed-thumbnails.mjs",
    "test:docs:iris": "pnpm run build:docs && pnpm run smoke:docs:iris",
    "test:files:iris": "pnpm run build && pnpm run smoke:files:iris",
    "test:git:iris": "pnpm run build:git && pnpm run smoke:git:iris",
    "test:git:install": "pnpm run test:git:install:copy && PW_APP_PORT=49173 playwright test e2e/git-shell.spec.ts --project=chromium && pnpm run test:git:install:docker",
    "test:git:install:copy": "node ./scripts/test-git-install-copy.mjs",
    "test:git:install:docker": "node ./scripts/test-git-install-command-docker.mjs",
    "test:maps:iris": "pnpm run build:maps && pnpm run smoke:maps:iris",
    "test:video:iris": "pnpm run build:video:iris && pnpm run smoke:video:iris",
    "test:boards:iris": "pnpm run build:boards && pnpm run smoke:boards:iris",
    "publish:docs:iris": "pnpm run build:docs && node ./scripts/publish-docs-iris.mjs",
    "publish:git:iris": "pnpm run build:git && node ./scripts/publish-git-iris.mjs",
    "publish:video:iris": "pnpm run build:video && node ./scripts/publish-video-iris.mjs",
    "publish:maps:iris": "pnpm run build:maps && node ./scripts/publish-maps-iris.mjs",
    "release:iris": "node ./scripts/release-site.mjs",
    "release:git:iris": "node ./scripts/release-site.mjs git",
    "release:all:iris": "node ./scripts/release-site.mjs all",
    "build:maps": "pnpm run build:deps && vite build --config vite.maps.config.ts",
    "build:boards": "pnpm run build:deps && vite build --config vite.boards.config.ts",
    "build:analyze": "vite build && echo '\nBundle stats: dist/stats.html\nBundle list: dist/stats-list.txt'",
    "preview": "vite preview",
    "preview:docs": "vite preview --config vite.docs.config.ts",
    "preview:git": "vite preview --config vite.git.config.ts",
    "preview:video": "vite preview --config vite.video.config.ts",
    "preview:maps": "vite preview --config vite.maps.config.ts",
    "preview:boards": "vite preview --config vite.boards.config.ts",
    "test": "pnpm run test:unit",
    "test:unit": "pnpm run build:deps && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:docker": "bash ./scripts/test-e2e-docker.sh",
    "test:e2e:fast": "E2E_FAST=1 playwright test",
    "test:e2e:integration": "playwright test e2e/anchor-links.spec.ts e2e/boards-app.spec.ts e2e/compression.spec.ts e2e/docs-image-collaboration.spec.ts e2e/explorer.test.ts e2e/git-basic.spec.ts e2e/git-branch-compare.spec.ts e2e/git-commit-status.spec.ts e2e/git-commit-view.spec.ts e2e/git-file-bar.spec.ts e2e/git-perf.spec.ts e2e/git-pr-interop.spec.ts e2e/git-status-edit.spec.ts e2e/link-visible-tree.spec.ts e2e/nip34-pull-requests.spec.ts e2e/search-navigation.spec.ts e2e/viewer-actions.spec.ts",
    "test:e2e:slow": "playwright test e2e/yjs-collaboration.spec.ts e2e/livestream-viewer.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@msgpack/msgpack": "^3.1.2",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@tiptap/core": "^2.26.2",
    "@tiptap/extension-collaboration": "^2.26.2",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/extension-image": "^2.27.1",
    "@tiptap/extension-placeholder": "^2.26.2",
    "@tiptap/pm": "^2.26.2",
    "@tiptap/starter-kit": "^2.26.2",
    "coco-cashu-core": "1.1.2-rc.29",
    "coco-cashu-indexeddb": "1.1.2-rc.29",
    "dexie": "^4.2.1",
    "dompurify": "^3.3.1",
    "fflate": "^0.8.2",
    "@hashtree/core": "0.1.3",
    "@hashtree/git": "0.1.2",
    "@hashtree/dexie": "0.1.3",
    "@hashtree/tree-root": "0.1.1",
    "@hashtree/worker": "0.1.11",
    "@hashtree/index": "0.1.3",
    "@hashtree/merge": "0.1.0",
    "@hashtree/nostr": "0.1.3",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "marked": "^15.0.0",
    "minidenticons": "^4.2.1",
    "ndk": "workspace:*",
    "nostr-social-graph": "1.0.33",
    "nostr-tools": "^2.18.2",
    "nostr-wasm": "^0.1.0",
    "prismjs": "^1.29.0",
    "qrcode": "^1.5.4",
    "wasm-git": "^0.0.13",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.75",
    "@types/prismjs": "^1.26.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/dompurify": "^3.2.0",
    "@types/leaflet": "^1.9.14",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@unocss/preset-icons": "^66.5.9",
    "@unocss/preset-typography": "^66.5.9",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "globals": "^16.5.0",
    "html2canvas": "^1.4.1",
    "open-props": "^1.7.16",
    "rollup-plugin-visualizer": "^6.0.5",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.4",
    "svelte-eslint-parser": "^1.4.1",
    "typescript": "^5.3.0",
    "unocss": "^66.5.9",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17",
    "happy-dom": "^15.11.7",
    "workbox-precaching": "^7.4.0",
    "workbox-window": "^7.4.0",
    "ws": "^8.18.3"
  }
}
